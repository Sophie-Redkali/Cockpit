{% extends "cockpit/base.html" %}
{% load static %}

{% block title %}Cockpit — Projet{% endblock %}

{% block breadcrumb %}
Cockpit &gt; Projets &gt;
{% if projet %}{{ projet.nom_projet|default:"Projet sans nom" }}{% else %}Nouveau projet{% endif %}
{% endblock %}

{% block nav_menu %}
<li><a href="{% url 'accueil' %}">Accueil</a></li>
<li><a href="{% url 'contact_create' %}">Nouveau contact</a></li>
<li><a href="{% url 'projet_create' %}">Nouveau projet</a></li>
<li><a href="#">Voir tous les projets</a></li>
{% endblock %}

{% block content %}
<div class="cockpit-form-card">
    <div class="cockpit-projet-header">
        <h2>
            {% if projet %}{{ projet.nom_projet|default:"Projet sans nom" }}{% else %}Nouveau projet{% endif %}
        </h2>
        <span class="cockpit-badge">{{ form.instance.get_statut_actuel_display|default:"Vivier" }}</span>
    </div>

    {% if form.non_field_errors %}
        <div class="cockpit-alert">{{ form.non_field_errors }}</div>
    {% endif %}

    <form method="post" enctype="multipart/form-data">
        {% csrf_token %}

        <!-- Onglets -->
        <div class="cockpit-tabs" role="tablist">
            {% for cle, libelle, champs in onglets %}
            <button type="button"
                    class="cockpit-tab{% if forloop.first %} is-active{% endif %}"
                    data-tab-target="tab-{{ cle }}"
                    role="tab">
                {{ libelle }}
            </button>
            {% endfor %}
        </div>

        <!-- Panneaux -->
        {% for cle, libelle, champs in onglets %}
        <div class="cockpit-tab-panel{% if forloop.first %} is-active{% endif %}" id="tab-{{ cle }}" role="tabpanel">

            {% if cle == "general" %}
                <div class="cockpit-field">
                    <label for="{{ form.nom_projet.id_for_label }}">Nom du projet</label>
                    {{ form.nom_projet }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.acronyme_projet.id_for_label }}">Acronyme</label>
                    {{ form.acronyme_projet }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.strat.id_for_label }}">Programme stratégique</label>
                    {{ form.strat }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.type_projet.id_for_label }}">Type de projet</label>
                    {{ form.type_projet }}
                </div>
                <div class="cockpit-field" id="wrapper-type-autre" style="display:none;">
                    <label for="{{ form.type_projet_autre.id_for_label }}">Préciser le type</label>
                    {{ form.type_projet_autre }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.nom_appel_contrat.id_for_label }}">Nom de l'appel / du contrat</label>
                    {{ form.nom_appel_contrat }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.date_debut_prevu.id_for_label }}">Date de début prévue</label>
                    {{ form.date_debut_prevu }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.date_fin_prevu.id_for_label }}">Date de fin prévue</label>
                    {{ form.date_fin_prevu }}
                </div>
                <div class="cockpit-field">
                    <label>Jalons (kickoff / mi-parcours / final)</label>
                    <div class="cockpit-inline-group">
                        {{ form.event_kickoff }}
                        {{ form.event_middle }}
                        {{ form.event_fin }}
                    </div>
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.confidentiel.id_for_label }}">
                        {{ form.confidentiel }} Projet confidentiel
                    </label>
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.reussite_estime.id_for_label }}">Estimation de réussite (%)</label>
                    {{ form.reussite_estime }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.documents.id_for_label }}">Documents (optionnel, plusieurs fichiers possibles)</label>
                    {{ form.documents }}
                </div>
            {% endif %}

            {% if cle == "scientifique" %}
                <div class="cockpit-field">
                    <label for="{{ form.contrib_vedecom.id_for_label }}">Contribution Vedecom</label>
                    {{ form.contrib_vedecom }}
                </div>
                <p class="cockpit-placeholder">
                    Lots, livrables et thèses rattachées : à venir (en attente du schéma des tables correspondantes).
                </p>
            {% endif %}

            {% if cle == "benefices" %}
                <!-- Section bénéfices -->
                <div class="cockpit-eval-section">
                    <h3>Bénéfices</h3>
                    {{ benefice_formset.management_form }}
                    <div id="benefice-rows">
                        {% for eval_form in benefice_formset %}
                        <div class="cockpit-eval-row">
                            {{ eval_form.id }}
                            {{ eval_form.contenu }}
                            {% if eval_form.instance.pk %}
                            <label class="cockpit-eval-delete">
                                {{ eval_form.DELETE }} Supprimer
                            </label>
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>
                    <button type="button" class="cockpit-btn-secondary" id="add-benefice-row">+ Ajouter un bénéfice</button>
                </div>
                <!-- gabarit caché utilisé par le JS pour cloner une nouvelle ligne de bénéfice -->
                    <div id="benefice-empty-form" style="display:none;">
                        <div class="cockpit-eval-row">
                            {{ benefice_formset.empty_form.contenu }}
                        </div>
                    </div>
                </div>

                <!-- Section Contre-bénéfices -->
                <div class="cockpit-eval-section">
                    <h3>Contre-bénéfices</h3>
                    {{ contre_formset.management_form }}
                    <div id="contre-rows">
                        {% for eval_form in contre_formset %}
                        <div class="cockpit-eval-row">
                            {{ eval_form.id }}
                            {{ eval_form.contenu }}
                            {% if eval_form.instance.pk %}
                            <label class="cockpit-eval-delete">
                                {{ eval_form.DELETE }} Supprimer
                            </label>
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>
                    <button type="button" class="cockpit-btn-secondary" id="add-contre-row">+ Ajouter un contre-bénéfice</button>
                    <!-- gabarit caché utilisé par le JS pour cloner une nouvelle ligne de contre-bénéfice -->
                    <div id="contre-empty-form" style="display:none;">
                        <div class="cockpit-eval-row">
                            {{ contre_formset.empty_form.contenu }}
                        </div>
                    </div>
                </div>

                <p class="cockpit-placeholder">
                    Bénéfices / contre-bénéfices détaillés : lister tous les bénéfices et contre-bénéfices envisagés.
                </p>
            {% endif %}
            

            {% if cle == "financier" %}
                <div class="cockpit-field">
                    <label for="{{ form.budget_total.id_for_label }}">Budget total</label>
                    {{ form.budget_total }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.budget_vedecom.id_for_label }}">Budget Vedecom</label>
                    {{ form.budget_vedecom }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.pm_valide.id_for_label }}">PM validés</label>
                    {{ form.pm_valide }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.pm_rate_projet.id_for_label }}">Taux PM projet</label>
                    {{ form.pm_rate_projet }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.call_eu.id_for_label }}">Appel européen</label>
                    {{ form.call_eu }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.ngrant_eu.id_for_label }}">N° de grant EU</label>
                    {{ form.ngrant_eu }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.core_group_eu.id_for_label }}">{{ form.core_group_eu }} Core group EU</label>
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.sr_pilot_eu.id_for_label }}">{{ form.sr_pilot_eu }} SR pilot EU</label>
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.lump_sum_eu.id_for_label }}">{{ form.lump_sum_eu }} Lump sum EU</label>
                </div>
            {% endif %}

            {% if cle == "decision" %}
                <div class="cockpit-field">
                    <label>Statut actuel</label>
                    <p class="cockpit-readonly">{{ form.instance.get_statut_actuel_display }}</p>
                    <p class="cockpit-placeholder">
                        Le changement de statut sera géré par un circuit de décision dédié (droits administrateur), pas encore en place.
                    </p>
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.date_debut_reel.id_for_label }}">Date de début réelle</label>
                    {{ form.date_debut_reel }}
                </div>
                <div class="cockpit-field">
                    <label for="{{ form.date_fin_reel.id_for_label }}">Date de fin réelle</label>
                    {{ form.date_fin_reel }}
                </div>
            {% endif %}

        </div>
        {% endfor %}

        <button type="submit" class="cockpit-btn">Enregistrer</button>
    </form>
</div>
{% endblock %}

{% block extra_scripts %}
<script>
    // Bascule d'onglets, sans rechargement de page
    document.querySelectorAll('.cockpit-tab').forEach(function (tabButton) {
        tabButton.addEventListener('click', function () {
            document.querySelectorAll('.cockpit-tab').forEach(function (b) { b.classList.remove('is-active'); });
            document.querySelectorAll('.cockpit-tab-panel').forEach(function (p) { p.classList.remove('is-active'); });

            tabButton.classList.add('is-active');
            document.getElementById(tabButton.dataset.tabTarget).classList.add('is-active');
        });
    });

    // Affichage conditionnel du champ "préciser le type"
    const typeSelect = document.getElementById('id_type_projet');
    const wrapperAutre = document.getElementById('wrapper-type-autre');
    if (typeSelect && wrapperAutre) {
        function toggleTypeAutre() {
            wrapperAutre.style.display = (typeSelect.value === 'autre') ? 'block' : 'none';
        }
        typeSelect.addEventListener('change', toggleTypeAutre);
        toggleTypeAutre();
    }

    // Ajout dynamique de lignes pour les formsets bénéfices / contre-bénéfices
    function setupFormsetAdd(addButtonId, rowsContainerId, emptyFormId, prefix) {
        const addButton = document.getElementById(addButtonId);
        const rowsContainer = document.getElementById(rowsContainerId);
        const emptyFormTemplate = document.getElementById(emptyFormId);
        const totalFormsInput = document.querySelector(`#id_${prefix}-TOTAL_FORMS`);
 
        if (!addButton || !rowsContainer || !emptyFormTemplate || !totalFormsInput) return;
 
        addButton.addEventListener('click', function () {
            const formIndex = parseInt(totalFormsInput.value, 10);
            const newRowHtml = emptyFormTemplate.innerHTML.replace(/__prefix__/g, formIndex);
 
            const wrapper = document.createElement('div');
            wrapper.innerHTML = newRowHtml;
            rowsContainer.appendChild(wrapper.firstElementChild);
 
            totalFormsInput.value = formIndex + 1;
        });
    }
 
    setupFormsetAdd('add-benefice-row', 'benefice-rows', 'benefice-empty-form', 'benefice');
    setupFormsetAdd('add-contre-row', 'contre-rows', 'contre-empty-form', 'contre');
</script>
{% endblock %}